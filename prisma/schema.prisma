generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Country {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String

  states    State[]

  createdAt DateTime @default(now())
}

model State {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String

  countryId   Int
  country     Country @relation(fields: [countryId], references: [id])

  districts   District[]

  createdAt   DateTime @default(now())
}

model District {
  id           Int      @id @default(autoincrement())
  code         String
  name         String

  stateId      Int
  state        State @relation(fields: [stateId], references: [id])

  subDistricts SubDistrict[]

  createdAt    DateTime @default(now())

  @@unique([code, stateId])
}

model SubDistrict {
  id          Int      @id @default(autoincrement())
  code        String
  name        String

  districtId  Int
  district    District @relation(fields: [districtId], references: [id])

  villages    Village[]

  createdAt   DateTime @default(now())

  @@unique([code, districtId])
}

model Village {
  id            Int      @id @default(autoincrement())
  code          String   @unique
  name          String

  subDistrictId Int
  subDistrict   SubDistrict @relation(fields: [subDistrictId], references: [id])

  latitude      Float?
  longitude     Float?

  createdAt     DateTime @default(now())

  @@index([name])
}

model ApiKey {
  id        String   @id @default(cuid())
  name      String
  apiKey    String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model SearchLog {
  id         Int      @id @default(autoincrement())
  query      String
  searchedAt DateTime @default(now())

  ipAddress  String?
  state      String?

  @@map("SearchLog")
}

model ApiUsage {
  id        Int      @id @default(autoincrement())
  apiKey    String
  endpoint  String
  createdAt DateTime @default(now())
}

model User {
  id        Int      @id @default(autoincrement())
  fullName  String
  email     String   @unique
  password  String
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
